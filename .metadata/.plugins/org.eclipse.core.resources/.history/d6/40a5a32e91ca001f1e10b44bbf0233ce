package com.sit.sbeans;

import java.util.Date;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

@Component("wwmg")
public class WeekdayWishMessageGenerator{
	
	@Autowired
	private Date weekday;
	
	public String messageGenerator() {
		
		String day=weekday.toString();
		
		if((day.equalsIgnoreCase("sunday")) || (day.equalsIgnoreCase("monday"))){
			return "Happy Weekend, Enjoy your time... ";
		}
		
		return "Its WeekDay, Happy Working Hours";
	}

}
